# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=gere-uma-chave-segura-aqui
DEBUG=False
ALLOWED_HOSTS=.railway.app,localhost,127.0.0.1
FRONTEND_URL=https://seu-projeto.vercel.app

# ── Banco de dados (Railway preenche automaticamente ao adicionar PostgreSQL) ──
DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=sua-access-key
AWS_SECRET_ACCESS_KEY=sua-secret-key

# ── E-mail ────────────────────────────────────────────────────────────────────
EMAIL_HOST_USER=seu@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-de-app-gmail

# ── APIs externas ─────────────────────────────────────────────────────────────
GROQ_API_KEY=sua-groq-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=sua-google-maps-key
